{
  "$schema": "https://jsr.io/schema/config-file.v1.json",
  "name": "@murky-web/typebuddy",
  "version": "1.1.1",
  "license": "ISC",
  "exports": {
    ".": "./src/index.ts",
    "./biome": "./biome/index.ts",
    "./oxlint": "./oxlint/index.ts"
  },
  "publish": {
    "include": [
      "README.md",
      "src/**/*.ts",
      "oxlint/**/*.ts",
      "rules/**/*.ts",
      "biome/**/*.ts",
      "biome/*.grit",
      "biome/*.gritt"
    ],
    "exclude": [
      "tests/**",
      "smoke/**",
      "globals.ts",
      "dist/**",
      "node_modules/**"
    ]
  }
}
