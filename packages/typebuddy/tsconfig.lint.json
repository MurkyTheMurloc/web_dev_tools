{
  "$schema": "https://json.schemastore.org/tsconfig",
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "types": ["node", "vitest/globals"]
  },
  "include": [
    "src/**/*.ts",
    "rules/**/*.ts",
    "oxlint/**/*.ts",
    "biome/**/*.ts",
    "tests/**/*.ts",
    "smoke/**/*.ts",
    "tsdown.config.ts",
    "vitest.config.ts"
  ],
  "exclude": ["dist"]
}
