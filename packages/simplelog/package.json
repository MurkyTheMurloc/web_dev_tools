{
  "name": "@murky-web/simplelog",
  "version": "0.1.0",
  "private": true,
  "main": "./dist/logger.js",
  "module": "./dist/logger.js",
  "types": "./dist/logger.d.ts",
  "exports": {
    ".": {
      "import": "./dist/logger.js",
      "require": "./dist/logger.js",
      "types": "./dist/logger.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "bun run clean && tsdown",
    "clean": "rm -rf dist",
    "lint": "oxlint -c ./.oxlintrc.jsonc --tsconfig ./tsconfig.json --type-aware src tsdown.config.ts",
    "lint:fix": "oxlint -c ./.oxlintrc.jsonc --tsconfig ./tsconfig.json --type-aware --fix src tsdown.config.ts",
    "format": "oxfmt -c ../../node_modules/@murky-web/config/oxc/.oxfmtrc.jsonc src tsdown.config.ts",
    "format:check": "oxfmt -c ../../node_modules/@murky-web/config/oxc/.oxfmtrc.jsonc --check src tsdown.config.ts",
    "typecheck": "tsgo --project ./tsconfig.json --noEmit"
  },
  "license": "MIT",
  "description": "A simple wrapper around console to make logging enjoyable again",
  "type": "module",
  "dependencies": {},
  "devDependencies": {
    "@murky-web/config": "workspace:*"
  }
}
